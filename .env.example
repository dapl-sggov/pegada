# ============================================================
# FPL Ponte — Exemplo de configuração (12-factor)
# ============================================================
# Copie para .env e ajuste. NUNCA versionar o .env real.
# Em produção (CEGER), estas variáveis são injetadas pelo
# orquestrador de containers ou por ficheiro .env protegido.
# ============================================================

# --- Ambiente ---
NODE_ENV=development
PORT=3717
PUBLIC_URL=http://localhost:3717
# Atrás de reverse proxy (nginx/HAProxy no CEGER): true
TRUST_PROXY=false

# --- Base de dados PostgreSQL ---
# Formato: postgres://utilizador:password@host:porta/base
DATABASE_URL=postgres://fpl:fpl@localhost:5432/fpl
DB_POOL_MAX=10
DB_SSL=false
# Forçar modo legado SQLite (apenas dev/transição): true
DB_FORCE_SQLITE=false

# --- Redis (cache, sessões, rate-limit) ---
REDIS_URL=redis://localhost:6379
# Em dev, se Redis estiver em baixo cai para in-memory: true
REDIS_OPTIONAL=true

# --- Object storage (MinIO/S3 — anexos) ---
# driver: s3 (MinIO/S3) ou fs (filesystem local, só dev)
STORAGE_DRIVER=fs
S3_ENDPOINT=http://localhost:9000
S3_REGION=pt-ceger-1
S3_BUCKET=fpl-anexos
S3_ACCESS_KEY=fpl-minio
S3_SECRET_KEY=fpl-minio-secret
S3_FORCE_PATH_STYLE=true
STORAGE_FS_DIR=./data/anexos
STORAGE_MAX_BYTES=20971520

# --- Autenticação ---
# GERE UM SEGREDO FORTE: openssl rand -base64 48
JWT_SECRET=demo-fpl-ponte-jwt-secret-change-in-prod
JWT_TTL=8h
SESSION_COOKIE_NAME=fpl_session
COOKIE_SECURE=false
BCRYPT_ROUNDS=10

# --- Federação OIDC (autenticação.gov.pt) — desativada na v1.0 ---
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# --- Email transacional ---
# driver: outbox (guarda sem enviar — dev/staging) ou smtp (produção)
EMAIL_DRIVER=outbox
EMAIL_FROM=pegada-legislativa@sggoverno.gov.pt
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Integração RTRI (Assembleia da República) ---
# mode: mock (cache local) ou http (API real da AR)
RTRI_MODE=mock
RTRI_BASE_URL=
RTRI_API_KEY=
RTRI_SYNC_CRON=0 3 * * *

# --- Integração Consulta.Lex ---
# mode: manual (import CSV) | webhook | http
CONSULTA_LEX_MODE=manual
CL_WEBHOOK_KEY=cl-demo-key-change-in-prod
CONSULTA_LEX_BASE_URL=

# --- Integração Diário da República ---
DRE_MODE=manual
DRE_BASE_URL=https://dre.pt

# --- Observabilidade ---
METRICS_ENABLED=true
LOG_LEVEL=debug
LOG_FORMAT=pretty

# --- Retenção de dados (decisão SGGOV) ---
# Dados das FPL: indefinido (interesse público) — não configurável
RETENTION_LOGS_DIAS=1825
RETENTION_SESSOES_DIAS=30
RETENTION_TENTATIVAS_DIAS=7

# ============================================================
# Credenciais MinIO (apenas para docker-compose local)
# ============================================================
MINIO_ROOT_USER=fpl-minio
MINIO_ROOT_PASSWORD=fpl-minio-secret

# ============================================================
# Credenciais Postgres (apenas para docker-compose local)
# ============================================================
POSTGRES_USER=fpl
POSTGRES_PASSWORD=fpl
POSTGRES_DB=fpl
